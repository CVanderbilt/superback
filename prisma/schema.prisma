generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String?
  passwordHash  String
  role          UserRole       @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Super {
  id        String              @id @default(uuid())
  name      String
  url       String
  parsers   Parser[]
  products  NormalizedProduct[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model Parser {
  id        String       @id @default(uuid())
  superId   String
  super     Super        @relation(fields: [superId], references: [id], onDelete: Cascade)
  status    ParserStatus
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([superId])
}

model Category {
  id           String              @id @default(uuid())
  name         String              @unique
  products     NormalizedProduct[]
  translations CategoryAlias[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model CategoryAlias {
  id         String   @id @default(uuid())
  name       String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([name])
  @@index([name])
}

model NormalizedProduct {
  id                String          @id @default(uuid())
  superId           String
  super             Super           @relation(fields: [superId], references: [id], onDelete: Cascade)
  rawName           String
  rawData           Json
  name              String
  searchName        String
  measurementType   MeasurementType
  measurementValue  Decimal         @db.Decimal(10, 3)
  categoryId        String
  category          Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  url               String?
  description       String?
  tags              String[]        @default([])
  normalizationDate DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([superId])
  @@index([categoryId])
  @@index([searchName])
  @@index([tags], type: Gin)
}

enum UserRole {
  USER
  ADMIN
}

enum ParserStatus {
  ONGOING
  COMPLETED
  CANCELED
}

enum MeasurementType {
  KG
  L
  UNIT
}
